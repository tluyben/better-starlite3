{
  "name": "better-starlite3",
  "version": "1.0.0",
  "description": "Unified async SQLite API wrapping better-sqlite3, best-sqlite3, better-starlite, and flexdb-node",
  "keywords": ["sqlite", "better-sqlite3", "best-sqlite3", "better-starlite", "flexdb", "database", "async"],
  "author": "Tycho Andersen",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "build:watch": "tsc --project tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "test": "node --import tsx/esm --test 'tests/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "peerDependencies": {
    "better-sqlite3": ">=9.0.0",
    "best-sqlite3": ">=1.0.0",
    "flexdb-node": ">=0.1.0",
    "better-starlite": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": { "optional": true },
    "best-sqlite3": { "optional": true },
    "flexdb-node": { "optional": true },
    "better-starlite": { "optional": true }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "better-sqlite3": "^12.9.0",
    "best-sqlite3": "^1.0.19",
    "flexdb-node": "file:./3rdparty/flexdb-node",
    "better-starlite": "file:./3rdparty/better-starlite",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
