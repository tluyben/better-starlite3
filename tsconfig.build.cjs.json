{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist-cjs",
    "rootDir": "./src",
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "ignoreDeprecations": "5.0",
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "dist-cjs", "tests", "3rdparty"]
}
